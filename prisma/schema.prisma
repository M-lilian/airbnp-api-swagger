generator client {
  provider = "prisma-client-js"
}

// 💅 Part 2 Fix: url is removed because it's handled in prisma.config.ts
datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HOST
  GUEST
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  username         String    @unique
  phone            String
  password         String    // Secured by bcrypt
  role             Role      @default(GUEST)
  resetToken       String?   // For password recovery
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile          Profile?
  listings         Listing[]
  bookings         Booking[]
  avatar           String?
  avatarPublicId   String?
}

model Profile {
  id      Int     @id @default(autoincrement())
  bio     String?
  website String?
  country String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  Int     @unique
}

model Listing {
  id            Int            @id @default(autoincrement())
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  type          ListingType
  amenities     String[]
  rating        Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  hostId        Int
  host          User           @relation(fields: [hostId], references: [id], onDelete: Cascade)

  bookings      Booking[]
  photos        ListingPhoto[]

  // 💅 Part 3: Listing Indexes
  @@index([location])
  @@index([pricePerNight])
  @@index([type])
  @@index([hostId])
  @@index([type, location]) // Composite index for advanced filtering!
}

model Booking {
  id         Int           @id @default(autoincrement())
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  guestId    Int
  guest      User          @relation(fields: [guestId], references: [id], onDelete: Cascade)

  listingId  Int
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // 💅 Part 3: Booking Indexes
  @@index([guestId])
  @@index([listingId])
  @@index([listingId, checkIn, checkOut]) // For that atomic conflict check
}

model ListingPhoto {
  id        Int     @id @default(autoincrement())
  url       String
  publicId  String
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}